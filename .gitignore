# ══════════════════════════════════════════════════════════════════════════════
# LaPoison .gitignore — Production-safe exclusions
# ══════════════════════════════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage
/test-results
/playwright-report
/blob-report

# ─── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Production build ────────────────────────────────────────────────────────
/build
/dist

# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── Private keys ─────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx

# ─── Debug logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
*.log

# ─── Environment files (NEVER commit secrets) ────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.production.local
.env.development
.env.development.local

# ─── Vercel ───────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript build artifacts ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Turbo cache ──────────────────────────────────────────────────────────────
.turbo/

# ─── Supabase CLI local state ────────────────────────────────────────────────
supabase/.branches/
supabase/.temp/

# ─── Database migrations (schema managed via Supabase Dashboard) ─────────────
supabase/migrations/

# ─── Agent / IDE config files (not needed for production) ─────────────────────
.claude/
.antigravity/
.cursor/
AGENTS.md
CLAUDE.md
AGENT_STATE.json

# ─── Documentation (agent-generated, not needed for production) ──────────────
# README.md is kept (explicitly NOT ignored)
docs/AGENT_STATE_SCHEMA.md
docs/API_SPECT.md
docs/CACHE.md
docs/RATE_LIMIT_SPEC.md
docs/ROADMAP.md
docs/SEO_CHECKLIST.md
docs/background-setup.md
docs/migrations/

# ─── Pipeline data (large cached artifacts, not needed in repo) ──────────────
scripts/data/raw/
scripts/data/images/
scripts/data/i18n/
