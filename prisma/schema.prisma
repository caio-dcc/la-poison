generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  active
  past_due
  canceled
  trialing
  incomplete
}

enum PlanType {
  free
  pro_monthly
  pro_yearly
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  username         String?        @unique
  passwordHash     String?
  supabaseId       String?        @unique
  stripeCustomerId String?        @unique
  subscription     Subscription?
  createdBars      Bar[]          @relation("BarCreator")
  sharedBars       Bar[]          @relation("BarShares")
  submittedDrinks  UserDrink[]
  comments         Comment[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Subscription {
  id              String               @id @default(cuid())
  userId          String               @unique
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubId     String               @unique
  status          SubscriptionStatus
  currentPeriodEnd DateTime
  planType        PlanType
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model Bar {
  id            String          @id @default(cuid())
  name          String
  description   String?
  location      String?
  creatorId     String
  creator       User            @relation("BarCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  sharedWith    User[]          @relation("BarShares")
  inventory     InventoryItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Cocktail {
  id               String   @id @default(cuid())
  name             String
  description      String?  @db.Text
  category         String?
  alcoholic        Boolean  @default(true)
  glass            String?
  instructions     String?  @db.Text
  imageUrl         String?
  imagePath        String?
  slug             String   @unique
  metaTitlePT      String?
  metaTitleEN      String?
  metaTitleES      String?
  metaDescPT       String?  @db.Text
  metaDescEN       String?  @db.Text
  metaDescES       String?  @db.Text
  embeddingVector  Bytes?
  viewCount        Int      @default(0)
  ingredients      CocktailIngredient[]
  comments         Comment[]
  userSubmissions  UserDrink[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([category])
}

model Ingredient {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String?
  description String? @db.Text
  imageUrl   String?
  cocktails  CocktailIngredient[]
  inventoryItems InventoryItem[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CocktailIngredient {
  id         String   @id @default(cuid())
  cocktailId String
  cocktail   Cocktail @relation(fields: [cocktailId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  measurement String?
  unit       String?
  createdAt  DateTime @default(now())

  @@unique([cocktailId, ingredientId])
  @@index([ingredientId])
}

model InventoryItem {
  id        String   @id @default(cuid())
  barId     String
  bar       Bar      @relation(fields: [barId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  quantity  Int
  unit      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([barId, ingredientId])
}

model UserDrink {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cocktailId String?
  cocktail  Cocktail? @relation(fields: [cocktailId], references: [id], onDelete: SetNull)
  name      String
  description String? @db.Text
  imageUrl  String
  comment   String?  @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cocktailId String
  cocktail  Cocktail @relation(fields: [cocktailId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([cocktailId])
  @@index([userId])
}

model ChatbotUsage {
  id        String   @id @default(cuid())
  userId    String?
  ipHash    String?
  query     String   @db.Text
  tokensIn  Int
  tokensOut Int
  costUsd   Decimal  @db.Decimal(10, 6)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([ipHash, createdAt])
}
