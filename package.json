    "fix-images:r2": "node --env-file=.env scripts/fix-image-urls.mjs --r2",
    "enrich:test": "node --env-file=.env scripts/enrich-direct.mjs --limit 3",
    "monitor:cocktaildb": "node --env-file=.env scripts/monitor-cocktaildb-health.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/ssr": "^0.10.3",
