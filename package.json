    "@vercel/og": "^0.11.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "nodemailer": "^6.10.1",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "@xenova/transformers": "^2.17.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "next-sitemap": "^4.2.3",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "schema-dts": "^2.0.0",
    "shadcn-ui": "^0.9.5",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
