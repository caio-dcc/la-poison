{
  "name": "lapoison",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "seed": "tsx scripts/seed-db.ts",
    "ingest": "tsx scripts/ingest-cocktaildb.ts",
    "enrich": "node --env-file=.env scripts/enrich-direct.mjs",
    "embeddings": "tsx scripts/generate-embeddings.ts",
    "chunk": "tsx scripts/chunk-cocktails.ts",
    "embed": "tsx scripts/embed-chunks.ts",
    "upload-chunks": "tsx scripts/upload-chunks.ts",
