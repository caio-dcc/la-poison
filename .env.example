# LaPoison environment variables — copy to .env.local and fill values.
# Never commit .env or .env.local. Only .env.example is checked in.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-side only. Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_KEY="sb_secret_..."

# ─── Database (direct connection, scripts only — not app runtime) ─────────────
# Dashboard → Project Settings → Database → Connection string → URI
# Rotate the password via Dashboard → Project Settings → Database → Reset password
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=public"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Dashboard → Products → Prices → API id
STRIPE_PRICE_ID_MONTHLY="price_..."
STRIPE_PRICE_ID_ANNUAL="price_..."

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
NEXT_PUBLIC_R2_PUBLIC_URL="https://<bucket>.r2.dev"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_ACCOUNT_ID=""

# ─── Anthropic ────────────────────────────────────────────────────────────────
# console.anthropic.com → API keys
ANTHROPIC_API_KEY="sk-ant-..."

# ─── App settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Any random 32+ character string. Used as HMAC key for IP hashing.
IP_HASH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Optional: Upstash Redis (not currently used) ─────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
